# BidOps dev 프로파일 환경변수 예시
# 이 파일을 .env로 복사한 뒤 실제 값을 채워서 사용하세요.
# .env 파일은 .gitignore에 포함되어 있어야 합니다.

# Spring 프로파일
SPRING_PROFILES_ACTIVE=dev

# Azure Document Intelligence (OCR)
AZURE_DI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_DI_API_KEY=your-azure-di-api-key
AZURE_DI_ENABLED=true

# OpenAI (RFP 분석)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL 기본값: https://api.openai.com (/v1 붙이지 말 것)
